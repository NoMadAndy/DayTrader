{
  "permissions": {
    "allow": [
      "Bash(npm test:*)",
      "Bash(npm run:*)",
      "Bash(npx tsc:*)",
      "Bash(pytest:*)",
      "Bash(docker-compose:*)",
      "Bash(docker compose:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(rm -rf:*)",
      "Bash(git commit*--no-verify*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./**/.env)"
    ]
  }
}
