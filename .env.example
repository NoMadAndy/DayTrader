# ============================================================================
# DayTrader — .env.example (Commit dies, niemals .env)
# Quelle der Wahrheit für root-level Env-Vars. `.env` muss dieselben Keys
# enthalten, nur mit echten Werten. Services-spezifische Defaults (interne
# Thread-Counts, Sub-Service-URLs) stehen in docker-compose.yml.
# ============================================================================

# --- App Core --------------------------------------------------------------
APP_ENV=production                # production | development
APP_PORT=3000                     # Public frontend port (Nginx in prod, Vite in override)
BACKEND_PORT=3001
ML_SERVICE_PORT=8000
RL_SERVICE_PORT=8001
POSTGRES_PORT=5432
CORS_ORIGIN=*                     # Tighten in prod (z.B. https://daytrader.macherwerkstatt.cc)

# --- Postgres --------------------------------------------------------------
POSTGRES_DB=daytrader
POSTGRES_USER=daytrader
POSTGRES_PASSWORD=change_me        # Strong password in .env

# --- Build Info (üblicherweise via CI gesetzt) -----------------------------
BUILD_VERSION=1.43.4
BUILD_COMMIT=dev
BUILD_TIME=

# --- GPU / Threading -------------------------------------------------------
USE_CUDA=auto                     # auto | true | false
OMP_NUM_THREADS=2
MKL_NUM_THREADS=2
OPENBLAS_NUM_THREADS=2
TORCH_NUM_THREADS=2
MAX_CONCURRENT_TRAININGS=1

# --- ML-Service Tuning -----------------------------------------------------
ML_SEQUENCE_LENGTH=60             # Eingabe-Historie (Tage) für LSTM/Transformer
ML_FORECAST_DAYS=14               # Vorhersagehorizont
ML_EPOCHS=100
ML_LEARNING_RATE=0.001
ML_SERVICE_CPUS=2.0

# --- RL-Trading-Service Tuning ---------------------------------------------
RL_LEARNING_RATE=0.0003
RL_DEFAULT_TIMESTEPS=100000
RL_SERVICE_CPUS=2.0

# --- Market-Data Provider Keys (server-side) -------------------------------
# Frontend-Bundle enthält KEINE Keys. Backend liest diese direkt. Nutzer können
# eigene Keys in Settings hinterlegen (user_settings.api_keys) — diese haben
# Vorrang vor den Server-Defaults via resolveProviderKey().
FINNHUB_API_KEY=
ALPHA_VANTAGE_API_KEY=
TWELVE_DATA_API_KEY=

# --- News Provider Keys (server-side) --------------------------------------
NEWSAPI_KEY=                      # newsapi.org (free tier: nur server-side erlaubt)
NEWSDATA_API_KEY=                 # newsdata.io
MARKETAUX_API_KEY=                # marketaux.com
FMP_API_KEY=                      # financialmodelingprep.com
TIINGO_API_KEY=                   # tiingo.com
MEDIASTACK_API_KEY=               # mediastack.com

# --- Sentiment-Pipeline Features -------------------------------------------
ENABLE_SEMANTIC_DEDUP=false       # true = FinBERT-Embedding-Dedup vor Aggregation
SEMANTIC_DEDUP_THRESHOLD=0.92     # Cosine-Similarity-Threshold

# --- Internal Service Auth -------------------------------------------------
# Shared secret für Service-zu-Service-Calls (rl-trading-service → backend).
# Requests mit Header X-Internal-Service-Token == diesem Wert werden nicht
# rate-limited. Leer lassen = kein Bypass (dann müssen Limits hoch genug sein
# für den Orchestrierungs-Traffic). In .env auf zufälligen String setzen.
INTERNAL_SERVICE_TOKEN=

# --- Frontend Build --------------------------------------------------------
VITE_API_BASE_URL=/api
VITE_PREFERRED_DATA_SOURCE=yahoo  # yahoo | finnhub | alphaVantage | twelveData
